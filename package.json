{
  "name": "cc-journal",
  "version": "0.1.0",
  "description": "Local analytics & daily journal for Claude Code — sessions, token usage, GitHub-style heatmap dashboard, and daily work reports. 100% offline, nothing leaves your machine.",
  "type": "module",
  "bin": {
    "cc-journal": "dist/cli.js",
    "journal": "dist/cli.js"
  },
  "files": [
    "dist",
    "web",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-vendor.mjs",
    "prepare": "npm run build",
    "dev": "tsx src/cli.ts",
    "stats": "tsx src/cli.ts stats",
    "serve": "tsx src/cli.ts serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pickjason/cc-journal.git"
  },
  "homepage": "https://github.com/pickjason/cc-journal#readme",
  "bugs": "https://github.com/pickjason/cc-journal/issues",
  "keywords": [
    "claude-code",
    "claude",
    "token-usage",
    "analytics",
    "heatmap",
    "dashboard",
    "journal",
    "usage",
    "cli"
  ],
  "author": "pickjason",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "echarts": "^5.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
